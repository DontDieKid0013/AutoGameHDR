<Window x:Class="AutoGameHDR.GlobalListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Online Cloud Whitelist (Read-only)" Height="500" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource PrimaryText}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="This list is automatically updated daily from GitHub and includes games with native HDR support." TextWrapping="Wrap" Margin="0,0,0,10" Foreground="{DynamicResource SecondaryText}"/>

        <ListBox x:Name="GameList" Grid.Row="1" BorderThickness="1" 
                 Background="{DynamicResource WindowBackground}"
                 Foreground="{DynamicResource PrimaryText}"
                 BorderBrush="{DynamicResource BorderBrush}"/>

        <Button Grid.Row="2" Content="Close" Click="Close_Click" Padding="20,5" HorizontalAlignment="Center" Margin="0,15,0,0"/>
    </Grid>
</Window>